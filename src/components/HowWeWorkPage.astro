---
import { philosophyCards, type PhilosophyCard } from '../data/philosophyCards';
import { howWeWorkBreatherPullQuote } from '../data/testimonials';
import KeystoneBulletIcon from './KeystoneBulletIcon.astro';

/** Fallback if a card omits `sectionImage`. */
const sectionPlaceholderImage = '/images/hero-interior.jpg';

function splitIntroFirstSentence(pageIntro: string): { lead: string | null; rest: string } {
	const m = pageIntro.match(/^(.+?[.!?])\s+(.*)$/s);
	if (!m) return { lead: null, rest: pageIntro };
	return { lead: m[1].trim(), rest: m[2].trim() };
}

function bandContentModel(card: PhilosophyCard) {
	let introLead: string | null = null;
	let introBody = card.pageIntro;
	let leadBullet: string | null = null;
	let displayBullets: readonly string[] = card.bullets;

	if (card.leadEmphasis === 'firstBullet') {
		leadBullet = card.bullets[0] ?? null;
		displayBullets = card.bullets.slice(1);
	} else if (card.leadEmphasis === 'introFirstSentence') {
		const s = splitIntroFirstSentence(card.pageIntro);
		if (s.lead) {
			introLead = s.lead;
			introBody = s.rest;
		}
	}

	const listItems = displayBullets;
	const needsMobileCollapse = listItems.length > 3;

	return { introLead, introBody, leadBullet, listItems, needsMobileCollapse };
}

/** Mid-page breather split after first half of philosophy bands. */
const breatherAfterIndex = Math.ceil(philosophyCards.length / 2);
/** Replace with verified figures for your market. */
const breatherStats = [
	{ value: '15+', label: 'years in business' },
	{ value: '500+', label: 'projects delivered' },
	{ value: '10-year', label: 'workmanship warranty' },
] as const;
---

<div class="how-we-work-page">
	<header class="how-we-work-hero">
		<div class="how-we-work-hero__inner">
			<h1 class="how-we-work-hero__title type-h2-48-700 kr-motion-enter-fade-up-sm">How we work</h1>
			<p class="how-we-work-hero__lede type-large-body-18-400 kr-motion-enter-fade-up-sm kr-motion-delay-1">
				We keep things clear, calm, and well organised, from the first conversation to completion. Honest communication,
				sound craftsmanship, and respect for your home, your time, and your privacy run through everything we do.
			</p>
		</div>
	</header>

	{
		philosophyCards.map((card, i) => {
			const { title, iconSrc, sectionImage } = card;
			const { introLead, introBody, leadBullet, listItems, needsMobileCollapse } = bandContentModel(card);
			const mobileExtraCount = listItems.length > 3 ? listItems.length - 3 : 0;
			const listItemsMobileHead = listItems.slice(0, 3);
			const listItemsMobileTail = listItems.slice(3);

			return (
				<>
					{
						i === breatherAfterIndex && (
							<div class="how-we-work-breather" role="region" aria-labelledby="how-we-work-breather-heading">
								<div class="how-we-work-breather__inner">
									<hr class="how-we-work-breather__rule" />
									<h2 id="how-we-work-breather-heading" class="how-we-work-breather__title type-heading-24-700 kr-motion-enter-fade-up-sm">
										What you can expect from day one
									</h2>
									<p class="how-we-work-breather__lede type-large-body-18-400 kr-motion-enter-fade-up-sm kr-motion-delay-1">
										Clear expectations, steady communication, and workmanship you can see, without the noise of a
										typical build.
									</p>
									<dl class="how-we-work-breather__stats">
										{
											breatherStats.map(({ value, label }, si) => (
												<div
													class:list={[
														'how-we-work-breather__stat',
														'kr-motion-enter-fade-up-sm',
														si === 1 ? 'kr-motion-delay-1' : undefined,
														si === 2 ? 'kr-motion-delay-2' : undefined,
													]}
												>
													<dt class="how-we-work-breather__stat-value">{value}</dt>
													<dd class="how-we-work-breather__stat-label type-large-body-18-400">{label}</dd>
												</div>
											))
										}
									</dl>
									<figure class="how-we-work-breather__quote kr-motion-enter-fade-in">
										<blockquote class="how-we-work-breather__quote-text type-large-body-18-400">
											<p>{howWeWorkBreatherPullQuote.text}</p>
										</blockquote>
										<figcaption class="how-we-work-breather__quote-cite">
											{howWeWorkBreatherPullQuote.name}, {howWeWorkBreatherPullQuote.role}
										</figcaption>
									</figure>
								</div>
							</div>
						)
					}
					<section class:list={['how-we-work-band', i % 2 === 1 && 'how-we-work-band--flip']} aria-labelledby={`how-we-work-h-${i}`}>
						<div
							class:list={[
								'how-we-work-band__inner',
								'kr-motion-enter-fade-up-sm',
								i % 3 === 1 ? 'kr-motion-delay-1' : undefined,
								i % 3 === 2 ? 'kr-motion-delay-2' : undefined,
							]}
						>
							<div class="how-we-work-band__text">
								<div class="how-we-work-band__icon" aria-hidden="true">
									<img class="how-we-work-band__icon-img" src={iconSrc} alt="" width="28" height="28" decoding="async" />
								</div>
								<h2 id={`how-we-work-h-${i}`} class="how-we-work-band__title type-h3-20-700">
									{title}
								</h2>
								{introLead && <p class="how-we-work-band__lead type-body-18-700">{introLead}</p>}
								<p class="how-we-work-band__intro type-large-body-18-400">{introBody}</p>
								{leadBullet && <p class="how-we-work-band__lead type-body-18-700">{leadBullet}</p>}
								{
									needsMobileCollapse ? (
										<>
											<ul class="how-we-work-band__bullets how-we-work-band__list-desktop">
												{
													listItems.map((item, bi) => (
														<li class="how-we-work-band__bullet type-large-body-18-400">
															<span class="how-we-work-band__bullet-mark">
																<KeystoneBulletIcon />
															</span>
															<span class="how-we-work-band__bullet-text">{item}</span>
														</li>
													))
												}
											</ul>
											<div class="how-we-work-band__list-mobile">
												<ul class="how-we-work-band__bullets">
													{
														listItemsMobileHead.map((item, bi) => (
															<li class="how-we-work-band__bullet type-large-body-18-400">
																<span class="how-we-work-band__bullet-mark">
																	<KeystoneBulletIcon />
																</span>
																<span class="how-we-work-band__bullet-text">{item}</span>
															</li>
														))
													}
												</ul>
												<details class="how-we-work-band__also-mobile">
													<summary class="how-we-work-band__also-mobile-summary type-body-16-500">
														Also includes {mobileExtraCount} more {mobileExtraCount === 1 ? 'point' : 'points'}
													</summary>
													<ul class="how-we-work-band__bullets how-we-work-band__bullets--nested">
														{
															listItemsMobileTail.map((item, bi) => (
																<li class="how-we-work-band__bullet type-large-body-18-400">
																	<span class="how-we-work-band__bullet-mark">
																		<KeystoneBulletIcon />
																	</span>
																	<span class="how-we-work-band__bullet-text">{item}</span>
																</li>
															))
														}
													</ul>
												</details>
											</div>
										</>
									) : (
										<ul class="how-we-work-band__bullets">
											{
												listItems.map((item, bi) => (
													<li class="how-we-work-band__bullet type-large-body-18-400">
														<span class="how-we-work-band__bullet-mark">
															<KeystoneBulletIcon />
														</span>
														<span class="how-we-work-band__bullet-text">{item}</span>
													</li>
												))
											}
										</ul>
									)
								}
							</div>
							<div class="how-we-work-band__media">
								<img
									class="how-we-work-band__img"
									src={sectionImage ?? sectionPlaceholderImage}
									alt=""
									width="1200"
									height="800"
									loading={i === 0 ? 'eager' : 'lazy'}
									decoding="async"
								/>
							</div>
						</div>
					</section>
				</>
			);
		})
	}

	<aside class="how-we-work-cta" role="region" aria-labelledby="how-we-work-cta-heading">
		<div class="how-we-work-cta__inner">
			<h2 id="how-we-work-cta-heading" class="how-we-work-cta__title type-heading-24-700 kr-motion-enter-fade-up-sm">
				Ready to talk it through?
			</h2>
			<p class="how-we-work-cta__lede type-large-body-18-400 kr-motion-enter-fade-up-sm kr-motion-delay-1">
				Whether you are still weighing options or ready to move, we are happy to listen and advise, with no obligation.
			</p>
			<div class="how-we-work-cta__actions kr-motion-enter-fade-up-sm kr-motion-delay-2">
				<a class="how-we-work-cta__btn how-we-work-cta__btn--primary type-button-16-700" href="/contact/#discuss">
					Book a call
				</a>
				<a class="how-we-work-cta__btn how-we-work-cta__btn--ghost type-button-16-700" href="/contact/">Contact us</a>
			</div>
		</div>
	</aside>
</div>

<style>
	.how-we-work-page {
		background: var(--color-white);
	}

	.how-we-work-cta {
		padding: clamp(2rem, 5vw, 2.85rem) var(--section-pad-x);
		text-align: center;
		background: linear-gradient(
			165deg,
			color-mix(in srgb, var(--color-dark-khaki) 24%, var(--color-dark-gray)) 0%,
			var(--color-dark-gray) 38%,
			var(--color-dark-gray) 100%
		);
		border-top: 1px solid color-mix(in srgb, var(--color-card-icon-gold) 38%, var(--color-dark-gray));
	}

	.how-we-work-cta__inner {
		max-width: var(--layout-max-48);
		margin: 0 auto;
	}

	.how-we-work-cta__title {
		margin: 0 0 0.65rem;
		color: var(--color-white);
		text-transform: uppercase;
		letter-spacing: 0.02em;
		line-height: 1.25;
	}

	.how-we-work-cta__lede {
		margin: 0 auto 1.35rem;
		max-width: 32rem;
		color: rgba(255, 255, 255, 0.9);
		text-align: center;
		text-wrap: pretty;
	}

	.how-we-work-cta__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
		justify-content: center;
		align-items: center;
	}

	.how-we-work-cta__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.75rem;
		padding: 0.7rem 1.35rem;
		text-decoration: none;
		border-radius: 3px;
		transition:
			filter var(--motion-duration-200) var(--motion-ease-standard),
			background-color var(--motion-duration-200) var(--motion-ease-standard),
			border-color var(--motion-duration-200) var(--motion-ease-standard);
	}

	.how-we-work-cta__btn--primary {
		color: var(--color-white);
		background: var(--color-dark-khaki);
		border: 1px solid transparent;
	}

	.how-we-work-cta__btn--primary:hover {
		filter: brightness(1.08);
	}

	.how-we-work-cta__btn--ghost {
		color: var(--color-white);
		background: transparent;
		border: 1px solid color-mix(in srgb, var(--color-white) 52%, transparent);
	}

	.how-we-work-cta__btn--ghost:hover {
		background: color-mix(in srgb, var(--color-white) 9%, transparent);
		border-color: color-mix(in srgb, var(--color-white) 68%, transparent);
	}

	.how-we-work-cta__btn:focus-visible {
		outline: 2px solid var(--color-white);
		outline-offset: 3px;
	}

	@media (prefers-reduced-motion: reduce) {
		.how-we-work-cta__btn {
			transition: none;
		}
	}

	.how-we-work-breather {
		padding: clamp(2.25rem, 5vw, 3.25rem) var(--section-pad-x);
		background: linear-gradient(
			180deg,
			color-mix(in srgb, var(--color-card-icon-gold) 12%, var(--color-white)) 0%,
			var(--color-white) 100%
		);
		border-top: 1px solid color-mix(in srgb, var(--color-dark-gray) 8%, var(--color-white));
		border-bottom: 1px solid color-mix(in srgb, var(--color-dark-gray) 8%, var(--color-white));
	}

	.how-we-work-breather__inner {
		max-width: var(--layout-max-52);
		margin: 0 auto;
		text-align: center;
	}

	.how-we-work-breather__rule {
		width: min(12rem, 40%);
		margin: 0 auto 1.25rem;
		border: none;
		border-top: 2px solid color-mix(in srgb, var(--color-card-icon-gold) 55%, var(--color-dark-gray));
		opacity: 0.85;
	}

	.how-we-work-breather__title {
		margin: 0 auto 0.65rem;
		max-width: min(100%, 24rem);
		color: var(--color-dark-gray);
		text-transform: uppercase;
		letter-spacing: 0.02em;
		line-height: 1.25;
		text-wrap: balance;
	}

	.how-we-work-breather__lede {
		margin: 0 auto 1.75rem;
		max-width: 36rem;
		color: color-mix(in srgb, var(--color-dark-gray) 82%, var(--color-gray));
	}

	.how-we-work-breather__stats {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.25rem;
		margin: 0 0 2rem;
		padding: 0;
		border: none;
	}

	@media (min-width: 40rem) {
		.how-we-work-breather__stats {
			grid-template-columns: repeat(3, 1fr);
			gap: 1rem 1.5rem;
			margin-bottom: 2.25rem;
		}
	}

	.how-we-work-breather__stat {
		margin: 0;
		padding: 0.85rem 0.65rem 1rem;
		border-radius: 8px;
		background: var(--color-dark-khaki);
		border: 1px solid color-mix(in srgb, var(--color-white) 18%, var(--color-dark-khaki));
		box-shadow:
			0 1px 0 color-mix(in srgb, var(--color-black) 12%, transparent),
			0 6px 18px rgba(26, 27, 27, 0.12);
	}

	.how-we-work-breather__stat-value {
		margin: 0 0 0.2rem;
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1.5rem, 2.5vw, 1.85rem);
		line-height: 1.15;
		letter-spacing: 0.04em;
		color: var(--color-white);
	}

	.how-we-work-breather__stat-label {
		margin: 0;
		font-size: 0.9375rem;
		line-height: 1.45;
		color: color-mix(in srgb, var(--color-white) 88%, var(--color-white-smoke));
	}

	.how-we-work-breather__quote {
		margin: 0;
		padding: 0;
	}

	.how-we-work-breather__quote-text {
		margin: 0 auto;
		max-width: 38rem;
		color: color-mix(in srgb, var(--color-dark-gray) 88%, var(--color-gray));
		font-style: italic;
	}

	.how-we-work-breather__quote-text p {
		margin: 0;
	}

	.how-we-work-breather__quote-text p::before {
		content: '\201C';
	}

	.how-we-work-breather__quote-text p::after {
		content: '\201D';
	}

	.how-we-work-breather__quote-cite {
		margin: 0.85rem 0 0;
		font-family: var(--font-body);
		font-size: 0.8125rem;
		font-weight: 400;
		line-height: 1.45;
		letter-spacing: 0.02em;
		color: var(--color-gray);
	}

	.how-we-work-hero {
		position: relative;
		min-height: min(42vh, 22rem);
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: var(--color-dark-gray);
		background-image:
			linear-gradient(rgba(0, 0, 0, 0.42), rgba(0, 0, 0, 0.42)),
			linear-gradient(
				105deg,
				rgba(0, 0, 0, 0.38) 0%,
				rgba(0, 0, 0, 0.22) 48%,
				rgba(0, 0, 0, 0.52) 100%
			),
			url('/images/hero-interior.jpg');
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
	}

	.how-we-work-hero__inner {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: var(--layout-max-48);
		margin: 0 auto;
		padding: clamp(1.75rem, 4vw, 2.75rem) var(--section-pad-x);
		text-align: center;
	}

	.how-we-work-hero__title {
		margin: 0 0 0.85rem;
		color: var(--color-white);
		text-transform: uppercase;
		letter-spacing: 0.03em;
		text-shadow:
			0 1px 2px rgba(0, 0, 0, 0.45),
			0 4px 28px rgba(0, 0, 0, 0.35);
	}

	.how-we-work-hero__lede {
		margin: 0 auto;
		max-width: 40rem;
		color: rgba(255, 255, 255, 0.95);
		text-align: center;
	}

	.how-we-work-band {
		padding: clamp(2.5rem, 6vw, 4rem) var(--section-pad-x);
		border-top: 1px solid color-mix(in srgb, var(--color-dark-gray) 8%, var(--color-white));
	}

	.how-we-work-page > section:nth-of-type(odd) {
		background: color-mix(in srgb, var(--color-white-smoke) 55%, var(--color-white));
	}

	.how-we-work-page > section:nth-of-type(even) {
		background: var(--color-white);
	}

	.how-we-work-band__inner {
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(1.5rem, 4vw, 2.5rem);
		align-items: center;
		max-width: var(--layout-max-72);
		margin: 0 auto;
	}

	.how-we-work-band__text {
		order: 1;
	}

	.how-we-work-band__media {
		order: 2;
	}

	@media (min-width: 48rem) {
		.how-we-work-band__inner {
			grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
			gap: clamp(1.75rem, 4vw, 3rem);
		}

		.how-we-work-band:not(.how-we-work-band--flip) .how-we-work-band__text {
			order: 1;
		}

		.how-we-work-band:not(.how-we-work-band--flip) .how-we-work-band__media {
			order: 2;
		}

		.how-we-work-band--flip .how-we-work-band__media {
			order: 1;
		}

		.how-we-work-band--flip .how-we-work-band__text {
			order: 2;
		}
	}

	.how-we-work-band__icon {
		width: 2.75rem;
		height: 2.75rem;
		margin-bottom: 1rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		background: var(--color-card-icon-gold);
		color: var(--color-white);
		transition:
			transform var(--motion-duration-280) var(--motion-ease-standard),
			box-shadow var(--motion-duration-280) var(--motion-ease-standard);
	}

	.how-we-work-band__text:hover .how-we-work-band__icon {
		transform: scale(1.06);
		box-shadow: 0 6px 18px rgba(26, 27, 27, 0.12);
	}

	.how-we-work-band__icon-img {
		display: block;
		width: 1.375rem;
		height: 1.375rem;
		object-fit: contain;
		filter: brightness(0) invert(1);
	}

	.how-we-work-band__title {
		margin: 0 0 0.65rem;
		text-align: left;
		text-transform: uppercase;
		color: var(--color-dark-gray);
	}

	.how-we-work-band__intro {
		margin: 0 0 1.15rem;
		text-align: left;
		color: color-mix(in srgb, var(--color-dark-gray) 68%, var(--color-gray));
	}

	.how-we-work-band__lead {
		margin: 0 0 0.85rem;
		padding-left: 0.85rem;
		border-left: 3px solid color-mix(in srgb, var(--color-card-icon-gold) 70%, var(--color-dark-khaki));
		text-align: left;
		color: var(--color-dark-gray);
		line-height: 1.45;
	}

	.how-we-work-band__lead + .how-we-work-band__intro {
		margin-top: -0.15rem;
	}

	.how-we-work-band__bullets.how-we-work-band__list-desktop {
		display: none;
	}

	@media (min-width: 48rem) {
		.how-we-work-band__bullets.how-we-work-band__list-desktop {
			display: flex;
		}

		.how-we-work-band__list-mobile {
			display: none !important;
		}
	}

	.how-we-work-band__list-mobile {
		display: block;
	}

	.how-we-work-band__also-mobile {
		margin-top: 0.35rem;
		border-radius: 8px;
		background: color-mix(in srgb, var(--color-white-smoke) 65%, var(--color-white));
	}

	.how-we-work-band__also-mobile-summary {
		padding: 0.55rem 0.65rem;
		cursor: pointer;
		list-style: none;
		color: var(--color-dark-khaki);
		letter-spacing: 0.02em;
	}

	.how-we-work-band__also-mobile-summary::-webkit-details-marker {
		display: none;
	}

	.how-we-work-band__also-mobile-summary::after {
		content: '';
		display: inline-block;
		width: 0.35rem;
		height: 0.35rem;
		margin-left: 0.4rem;
		border-right: 2px solid currentColor;
		border-bottom: 2px solid currentColor;
		transform: rotate(45deg) translateY(-0.1rem);
		vertical-align: middle;
		opacity: 0.75;
	}

	.how-we-work-band__also-mobile[open] .how-we-work-band__also-mobile-summary::after {
