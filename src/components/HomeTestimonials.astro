---
const slides = [
	{
		quote: `I would highly recommend Keystone Renovations. They were amazing with a wealth of knowledge to help & advise. All the works were completed promptly and to a high standard.`,
		name: 'Sharon Brown',
		role: 'Home owner, Nottinghamshire',
	},
	{
		quote: `I cannot thank Keystone Renovations enough for their assistance and guidance upon finding myself thrust into the world of property renovation and repair after a family bereavement. They promptly pulled a team of contractors together to do the necessary work to get my Father in Law's property ready to market. The speed and quality of the work done was second to none and very competitively priced.`,
		name: 'Lisa Hosking',
		role: 'Home seller, Derbyshire',
	},
	{
		quote: `Keystone Renovations have organised and completed various property issues for me, from a full renovation of a rental flat to emergency works on a roof. They are always available, very proactive and on numerous occasions have gone above & beyond – even visiting a new tenant within 2 hours of being contacted about a boiler problem! Keystone have been a complete godsend for me and I would 100% recommend them for anything property related.`,
		name: 'Lisa Hosking',
		role: 'Landlord, Derbyshire',
	},
	{
		quote: `I recently engaged the services of Keystone Renovations for quite a large job, readying an old Manor House going up for sale. There were numerous jobs requiring urgent attention and involved many different skill levels. Keystone Renovations were able to organise a team very quickly. The quality of work was excellent all round! I wouldn't hesitate to recommend this company.`,
		name: 'Matthew Gardiner Legge',
		role: 'Oxford estate agent',
	},
	{
		quote: `I can't recommend Richard and his team highly enough. Richard is totally reliable, thorough, works to a high standard and is able to come up with solutions to problems. They were able to respond urgently to make good my rental property which had been left in very poor condition, turning it around promptly ready for the next tenant.`,
		name: 'Sarah Elliott',
		role: 'Landlord, Leicestershire',
	},
] as const;
---

<section id="home-testimonials" class="testimonials" aria-labelledby="testimonials-heading" tabindex="0">
	<h2 id="testimonials-heading" class="testimonials__sr-only">Client testimonials</h2>

	<div class="testimonials__inner">
		<div class="testimonials__mark" aria-hidden="true">“</div>

		<div class="testimonials__stars" aria-hidden="true">
			{
				Array.from({ length: 5 }).map(() => (
					<svg class="testimonials__star" viewBox="0 0 24 24" width="22" height="22" focusable="false">
						<path
							fill="currentColor"
							d="M12 2.5 14.6 9.2h7.1l-5.7 4.1 2.2 6.9L12 16.1 5.8 20.2l2.2-6.9L2.3 9.2h7.1L12 2.5z"
						/>
					</svg>
				))
			}
		</div>

		<div class="testimonials__row">
			<button
				type="button"
				class="testimonials__arrow testimonials__arrow--prev"
				data-t-prev
				aria-controls="testimonials-track"
				aria-label="Previous testimonial"
			>
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
					<path d="M15 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</button>

			<div id="testimonials-track" class="testimonials__track" aria-live="polite" aria-atomic="true">
				{
					slides.map((s, i) => (
						<div class:list={['testimonials__slide', { 'is-active': i === 0 }]} data-t-slide hidden={i !== 0}>
							<blockquote class="testimonials__blockquote">
								<p class="testimonials__quote">{s.quote}</p>
								<footer class="testimonials__cite">
									<strong class="testimonials__name">{s.name}</strong>
									<span class="testimonials__role">{s.role}</span>
								</footer>
							</blockquote>
						</div>
					))
				}
			</div>

			<button
				type="button"
				class="testimonials__arrow testimonials__arrow--next"
				data-t-next
				aria-controls="testimonials-track"
				aria-label="Next testimonial"
			>
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
					<path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</button>
		</div>

		<div class="testimonials__dots" role="tablist" aria-label="Choose testimonial">
			{
				slides.map((_, i) => (
					<button
						type="button"
						class:list={['testimonials__dot', { 'is-active': i === 0 }]}
						data-t-dot
						data-index={i}
						role="tab"
						aria-selected={i === 0 ? 'true' : 'false'}
						aria-label={`Testimonial ${i + 1} of ${slides.length}`}
					/>
				))
			}
		</div>
	</div>
</section>

<script>
	(() => {
		const root = document.getElementById('home-testimonials');
		if (!root) return;

		const slides = [...root.querySelectorAll('[data-t-slide]')];
		const dots = [...root.querySelectorAll('[data-t-dot]')];
		const prev = root.querySelector('[data-t-prev]');
		const next = root.querySelector('[data-t-next]');
		if (!slides.length || !prev || !next) return;

		let idx = 0;

		function show(i) {
			const n = slides.length;
			idx = ((i % n) + n) % n;
			slides.forEach((el, j) => {
				const on = j === idx;
				el.hidden = !on;
				el.classList.toggle('is-active', on);
			});
			dots.forEach((btn, j) => {
				const on = j === idx;
				btn.classList.toggle('is-active', on);
				btn.setAttribute('aria-selected', on ? 'true' : 'false');
			});
		}

		prev.addEventListener('click', () => show(idx - 1));
		next.addEventListener('click', () => show(idx + 1));
		dots.forEach((btn, j) => btn.addEventListener('click', () => show(j)));

		root.addEventListener('keydown', (e) => {
			if (e.key === 'ArrowLeft') {
				e.preventDefault();
				show(idx - 1);
			}
			if (e.key === 'ArrowRight') {
				e.preventDefault();
				show(idx + 1);
			}
		});
	})();
</script>

<style>
	.testimonials {
		/* Sits below all-white “Complete property solutions”; soft band for separation */
		background: var(--color-white-smoke);
		padding: clamp(3.5rem, 10vw, 6.5rem) clamp(1.25rem, 5vw, 2.5rem);
	}

	.testimonials__sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.testimonials__inner {
		max-width: 52rem;
		margin: 0 auto;
		text-align: center;
	}

	.testimonials__mark {
		font-family: var(--font-serif);
		font-size: clamp(4rem, 14vw, 7.5rem);
		line-height: 0.85;
		color: color-mix(in srgb, var(--color-card-icon-gold) 42%, var(--color-white-smoke));
		margin-bottom: 0.35rem;
		user-select: none;
	}

	.testimonials__stars {
		display: flex;
		justify-content: center;
		gap: 0.35rem;
		margin-bottom: clamp(1.5rem, 4vw, 2.25rem);
		color: var(--color-card-icon-gold);
	}

	.testimonials__star {
		display: block;
		flex-shrink: 0;
	}

	.testimonials__row {
		display: flex;
		align-items: center;
		gap: clamp(0.5rem, 2vw, 1.25rem);
		margin-bottom: clamp(1.75rem, 4vw, 2.5rem);
	}

	.testimonials__arrow {
		flex-shrink: 0;
		width: 2.75rem;
		height: 2.75rem;
		border-radius: 50%;
		border: 1px solid color-mix(in srgb, var(--color-dark-gray) 10%, var(--color-white-smoke));
		background: var(--color-white);
		color: color-mix(in srgb, var(--color-dark-gray) 38%, var(--color-white));
		display: inline-flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition:
			background 0.2s ease,
			color 0.2s ease,
			border-color 0.2s ease;
	}

	.testimonials__arrow:hover {
		color: var(--color-dark-gray);
		border-color: color-mix(in srgb, var(--color-dark-gray) 22%, var(--color-white));
		background: var(--color-white-smoke);
	}

	.testimonials__arrow:focus-visible {
		outline: 2px solid var(--color-card-icon-gold);
		outline-offset: 3px;
	}

	@media (max-width: 30rem) {
		.testimonials__arrow {
			width: 2.35rem;
			height: 2.35rem;
		}
	}

	.testimonials__track {
		flex: 1;
		min-width: 0;
		position: relative;
	}

	.testimonials__slide {
		animation: testimonials-fade 0.45s ease;
	}

	.testimonials__slide[hidden] {
		display: none;
	}

	@keyframes testimonials-fade {
		from {
			opacity: 0;
			transform: translateY(6px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.testimonials__slide {
			animation: none;
		}
	}

	.testimonials__blockquote {
		margin: 0;
		padding: 0;
		border: none;
	}

	.testimonials__quote {
		margin: 0 0 1.5rem;
		font-family: var(--font-body);
		font-size: clamp(1.25rem, 1rem + 1.15vw, 1.75rem);
		font-weight: 400;
		font-style: italic;
		line-height: 1.6;
		color: var(--color-dark-gray);
		text-align: center;
	}

	.testimonials__cite {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.2rem;
		font-family: var(--font-heading);
		font-size: 0.875rem;
		line-height: 1.35;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-dark-gray);
	}

	.testimonials__name {
		font-weight: 700;
	}

	.testimonials__role {
		font-weight: 600;
		letter-spacing: 0.06em;
		color: color-mix(in srgb, var(--color-dark-gray) 72%, var(--color-gray));
	}

	.testimonials__dots {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.5rem;
	}

	.testimonials__dot {
		padding: 0;
		border: none;
		background: color-mix(in srgb, var(--color-dark-gray) 18%, var(--color-white));
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 999px;
		cursor: pointer;
		transition:
			width 0.25s ease,
			background 0.2s ease;
	}

	.testimonials__dot.is-active {
		width: 1.75rem;
		background: var(--color-card-icon-gold);
	}

	.testimonials__dot:focus-visible {
		outline: 2px solid var(--color-card-icon-gold);
		outline-offset: 3px;
	}
</style>
