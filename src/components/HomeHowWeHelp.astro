---
const cards = [
	{
		href: '/services/',
		imageSrc: '/images/services/structural-design.png',
		imageAlt: 'Placeholder: renovation services',
		title: 'Our Services',
		description:
			'Structure, electrics, fixtures, finishes, and landscaping: every pillar scoped and coordinated by one team.',
		buttonLabel: 'View services',
	},
	{
		href: '/how-we-work/',
		imageSrc: '/images/how-we-work/know-how.png',
		imageAlt: 'Placeholder: how we work',
		title: 'How We Work',
		description:
			'Listening carefully, managing trades, and keeping your renovation on track from first conversation to handover.',
		buttonLabel: 'How we work',
	},
] as const;
---

<section class="how-we-help" aria-labelledby="how-we-help-heading">
	<div class="how-we-help__inner">
		<header class="how-we-help__header">
			<h2 id="how-we-help-heading" class="how-we-help__section-title type-h2-48-700 kr-motion-enter-fade-up-sm">
				Explore Keystone
			</h2>
		</header>

		<div class="how-we-help__grid">
			{
				cards.map(({ href, imageSrc, imageAlt, title, description, buttonLabel }, i) => (
					<article
						class:list={[
							'how-we-help__card',
							'kr-motion-enter-fade-up-sm',
							i === 1 ? 'kr-motion-delay-1' : undefined,
						]}
					>
						<a class="how-we-help__media-link" href={href} tabindex="-1" aria-hidden="true">
							<img
								class="how-we-help__image"
								src={imageSrc}
								alt={imageAlt}
								width="640"
								height="400"
								loading="lazy"
								decoding="async"
							/>
						</a>
						<div class="how-we-help__body">
							<h3 class="how-we-help__card-title type-h3-20-700">{title}</h3>
							<p class="how-we-help__description type-large-body-18-400">{description}</p>
							<a class="how-we-help__btn type-button-16-700" href={href}>
								{buttonLabel}
							</a>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.how-we-help {
		background: color-mix(in srgb, var(--color-white-smoke) 88%, var(--color-white));
		padding: var(--section-pad-y-how-we-help) var(--section-pad-x);
	}

	.how-we-help__inner {
		max-width: var(--layout-max-72);
		margin: 0 auto;
	}

	.how-we-help__header {
		text-align: center;
		max-width: var(--layout-max-48);
		margin: 0 auto 1.75rem;
	}

	.how-we-help__section-title {
		margin: 0;
		color: var(--color-dark-gray);
	}

	.how-we-help__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.15rem;
	}

	@media (min-width: 52rem) {
		.how-we-help__grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 1.25rem;
		}
	}

	.how-we-help__card {
		display: flex;
		flex-direction: column;
		background: var(--color-white);
		border-radius: 10px;
		overflow: hidden;
		box-shadow:
			0 1px 2px rgba(26, 27, 27, 0.05),
			0 6px 18px rgba(26, 27, 27, 0.07);
		transition:
			box-shadow var(--motion-duration-280) var(--motion-ease-standard),
			transform var(--motion-duration-280) var(--motion-ease-standard);
	}

	.how-we-help__card:hover,
	.how-we-help__card:focus-within {
		box-shadow:
			0 2px 4px rgba(26, 27, 27, 0.07),
			0 10px 26px rgba(26, 27, 27, 0.11),
			0 18px 44px rgba(26, 27, 27, 0.1);
		transform: translateY(-3px);
	}

	@media (prefers-reduced-motion: reduce) {
		.how-we-help__card {
			transition: none;
		}

		.how-we-help__card:hover,
		.how-we-help__card:focus-within {
			transform: none;
		}
	}

	.how-we-help__media-link {
		display: block;
		overflow: hidden;
		line-height: 0;
	}

	.how-we-help__image {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		object-position: center;
		transition: transform var(--motion-duration-380) var(--motion-ease-out-expo);
	}

	.how-we-help__card:hover .how-we-help__image,
	.how-we-help__card:focus-within .how-we-help__image {
		transform: scale(1.03);
	}

	@media (prefers-reduced-motion: reduce) {
		.how-we-help__image {
			transition: none;
		}

		.how-we-help__card:hover .how-we-help__image,
		.how-we-help__card:focus-within .how-we-help__image {
			transform: none;
		}
	}

	.how-we-help__body {
		display: flex;
		flex-direction: column;
		flex: 1;
		padding: clamp(1rem, 2vw, 1.35rem);
	}

	.how-we-help__card-title {
		margin: 0 0 0.5rem;
		text-transform: uppercase;
		color: var(--color-dark-gray);
	}

	.how-we-help__description {
		margin: 0 0 1.15rem;
		flex: 1;
		color: color-mix(in srgb, var(--color-dark-gray) 82%, var(--color-gray));
		text-wrap: pretty;
	}

	.how-we-help__btn {
		display: flex;
		width: 100%;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 1.35rem;
		text-decoration: none;
		color: var(--color-white);
		background: var(--color-dark-khaki);
		border-radius: 3px;
		transition:
			filter var(--motion-duration-200) var(--motion-ease-standard),
			transform var(--motion-duration-200) var(--motion-ease-standard);
	}

	.how-we-help__btn:hover {
		filter: brightness(1.06);
	}

	.how-we-help__btn:focus-visible {
		outline: 2px solid var(--color-card-icon-gold);
		outline-offset: 3px;
	}

	@media (prefers-reduced-motion: reduce) {
		.how-we-help__btn {
			transition: none;
		}
	}
</style>
