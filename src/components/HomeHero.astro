---
/**
 * Homepage hero — full-bleed imagery, overlay, primary H1, CTA.
 * Background asset: /public/images/hero-interior.jpg
 */
---

<section class="home-hero" aria-labelledby="hero-heading">
	<div class="home-hero__inner">
		<div class="home-hero__copy">
			<h1 id="hero-heading" class="home-hero__title type-h1-72-700 kr-motion-enter-fade-up-sm">
				<span class="home-hero__title-line">We are the</span>
				<span class="home-hero__title-line home-hero__title-line--accent">Keystone</span>
				<span class="home-hero__title-line">to your Project</span>
				<span class="home-hero__title-line home-hero__title-line--lede">the centre point from which all else depends.</span>
			</h1>
		</div>
		<a class="home-hero__cta type-button-16-700 kr-motion-enter-fade-up-sm kr-motion-delay-2" href="/contact/#discuss">Discuss your project</a>
	</div>
</section>

<style>
	.home-hero {
		position: relative;
		/* Shorter band on small viewports; tall immersive hero from md up */
		min-height: min(64vh, 30rem);
		display: flex;
		align-items: center;
		padding-left: max(var(--section-pad-x), env(safe-area-inset-left, 0px));
		padding-right: max(var(--section-pad-x), env(safe-area-inset-right, 0px));
		background-color: var(--color-dark-gray);
		/* Uniform dark wash + angled ramp so copy stays legible on bright glazing (right). */
		background-image:
			linear-gradient(rgba(0, 0, 0, 0.42), rgba(0, 0, 0, 0.42)),
			linear-gradient(
				105deg,
				rgba(0, 0, 0, 0.38) 0%,
				rgba(0, 0, 0, 0.22) 48%,
				rgba(0, 0, 0, 0.52) 100%
			),
			url('/images/hero-interior.jpg');
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
	}

	@media (min-width: 48rem) {
		.home-hero {
			min-height: min(88vh, 52rem);
			padding-left: var(--section-pad-x);
			padding-right: var(--section-pad-x);
		}
	}

	.home-hero__inner {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: var(--layout-max-72);
		margin-inline: auto;
		padding-block: var(--hero-inner-pad-y);
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		align-items: stretch;
		min-height: inherit;
		row-gap: 2.25rem;
		/* Allow flex child to shrink so long headlines wrap instead of clipping */
		min-width: 0;
	}

	@media (max-width: 47.99rem) {
		.home-hero__inner {
			padding-block: clamp(1.25rem, 3.5vh, 2.25rem);
		}
	}

	.home-hero__copy {
		max-width: var(--layout-max-52);
		min-width: 0;
		container-type: inline-size;
		container-name: hero-copy;
	}

	.home-hero__title.type-h1-72-700 {
		/* vw fallback; when CQ units are supported, size tracks the copy column */
		font-size: clamp(1.25rem, 5.2vw + 0.5rem, 4.5rem);
		line-height: 1.12;
		letter-spacing: 0.04em;
		overflow-wrap: break-word;
	}

	@supports (font-size: 1cqi) {
		.home-hero__title.type-h1-72-700 {
			font-size: clamp(1.25rem, 7cqi + 0.45rem, 4.5rem);
		}
	}

	@media (min-width: 75rem) {
		.home-hero__title.type-h1-72-700 {
			font-size: 4.5rem;
			line-height: 90px;
			letter-spacing: 3.6px;
		}
	}

	.home-hero__title {
		margin: 0 0 1.125rem;
		color: var(--color-white);
		text-shadow:
			0 1px 2px rgba(0, 0, 0, 0.45),
			0 4px 28px rgba(0, 0, 0, 0.35);
	}

	.home-hero__title-line {
		display: block;
	}

	.home-hero__title-line--accent {
		color: var(--color-dark-khaki);
		text-shadow:
			0 1px 2px rgba(0, 0, 0, 0.5),
			0 3px 20px rgba(0, 0, 0, 0.4);
	}

	.home-hero__title-line--lede {
		display: block;
		margin-top: 0.75rem;
		font-family: var(--font-body);
		font-weight: 400;
		font-style: italic;
		font-size: clamp(0.95rem, 0.8rem + 0.9vw, 1.375rem);
		line-height: 1.4;
		letter-spacing: 0.01em;
		color: rgba(255, 255, 255, 0.92);
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.45);
	}

	.home-hero__sub {
		margin: 0 0 1.75rem;
		max-width: none;
		text-align: left;
		color: rgba(255, 255, 255, 0.95);
		font-size: clamp(0.875rem, 0.78rem + 0.45vw, 1.125rem);
		line-height: calc(28 / 18);
		text-wrap: pretty;
	}

	@media (min-width: 48rem) {
		.home-hero__sub {
			white-space: nowrap;
		}
	}

	.home-hero__cta {
		align-self: flex-start;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.6rem 1.1rem;
		text-decoration: none;
		color: rgba(255, 255, 255, 0.92);
		background: transparent;
		border: 1px solid rgba(255, 255, 255, 0.55);
		border-radius: 3px;
		font-size: 0.8125rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		transition:
			background-color var(--motion-duration-200) var(--motion-ease-standard),
			border-color var(--motion-duration-200) var(--motion-ease-standard),
			color var(--motion-duration-200) var(--motion-ease-standard);
	}

	.home-hero__cta:hover {
		background: rgba(255, 255, 255, 0.1);
		border-color: rgba(255, 255, 255, 0.8);
		color: var(--color-white);
	}

	.home-hero__cta:focus-visible {
		outline: 2px solid var(--color-white);
		outline-offset: 3px;
	}

	@media (prefers-reduced-motion: reduce) {
		.home-hero__cta {
			transition: none;
		}
	}
</style>
