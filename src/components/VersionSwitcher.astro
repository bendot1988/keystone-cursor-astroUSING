---
/**
 * Client review toggle between production (original) and concise branch deploy.
 * Preserves the current path when switching.
 */
const originalOrigin = 'https://keystonerenovations.co.uk';
const conciseOrigin = 'https://concise-copy--keystoneastro.netlify.app';
const pathWithSearch = `${Astro.url.pathname}${Astro.url.search}`;
---

<div class="version-switcher" role="navigation" aria-label="Site version comparison">
	<p class="version-switcher__label">Compare versions</p>
	<div class="version-switcher__group" role="group" aria-label="Choose site version">
		<a
			class="version-switcher__btn"
			data-version="original"
			href={`${originalOrigin}${pathWithSearch}`}
		>
			Old version
		</a>
		<a
			class="version-switcher__btn"
			data-version="concise"
			href={`${conciseOrigin}${pathWithSearch}`}
		>
			New concise version
		</a>
	</div>
</div>

<script>
	(() => {
		const host = window.location.hostname;
		const isConcise = host.startsWith('concise-copy--');
		const isOriginal =
			host === 'keystonerenovations.co.uk' ||
			host === 'www.keystonerenovations.co.uk' ||
			host === 'keystoneastro.netlify.app';

		document.querySelectorAll('.version-switcher__btn').forEach((btn) => {
			const version = btn.getAttribute('data-version');
			const active =
				(version === 'concise' && isConcise) || (version === 'original' && isOriginal && !isConcise);
			btn.classList.toggle('is-active', active);
			if (active) btn.setAttribute('aria-current', 'page');
		});
	})();
</script>

<style>
	.version-switcher {
		position: fixed;
		z-index: 120;
		right: max(0.75rem, env(safe-area-inset-right));
		bottom: max(0.75rem, env(safe-area-inset-bottom));
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 0.35rem;
		max-width: min(20rem, calc(100vw - 1.5rem));
		padding: 0.55rem 0.6rem 0.6rem;
		background: color-mix(in srgb, var(--color-dark-gray) 94%, transparent);
		border: 1px solid color-mix(in srgb, var(--color-card-icon-gold) 45%, var(--color-dark-gray));
		border-radius: 8px;
		box-shadow: 0 10px 28px rgba(26, 27, 27, 0.28);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
	}

	.version-switcher__label {
		margin: 0;
		padding: 0 0.15rem;
		font-family: var(--font-heading);
		font-size: 0.625rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--color-white) 72%, transparent);
	}

	.version-switcher__group {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.35rem;
	}

	.version-switcher__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.25rem;
		padding: 0.4rem 0.55rem;
		border-radius: 5px;
		border: 1px solid color-mix(in srgb, var(--color-white) 22%, transparent);
		background: transparent;
		color: var(--color-white);
		text-decoration: none;
		text-align: center;
		font-family: var(--font-heading);
		font-size: 0.6875rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		line-height: 1.25;
		transition:
			background var(--motion-duration-200) var(--motion-ease-standard),
			border-color var(--motion-duration-200) var(--motion-ease-standard),
			color var(--motion-duration-200) var(--motion-ease-standard);
	}

	.version-switcher__btn:hover {
		background: color-mix(in srgb, var(--color-white) 10%, transparent);
		border-color: color-mix(in srgb, var(--color-white) 40%, transparent);
	}

	.version-switcher__btn.is-active {
		background: var(--color-dark-khaki);
		border-color: var(--color-dark-khaki);
		color: var(--color-white);
	}

	.version-switcher__btn:focus-visible {
		outline: 2px solid var(--color-card-icon-gold);
		outline-offset: 2px;
	}

	@media (max-width: 30rem) {
		.version-switcher {
			left: max(0.75rem, env(safe-area-inset-left));
			right: max(0.75rem, env(safe-area-inset-right));
			max-width: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.version-switcher__btn {
			transition: none;
		}
	}
</style>
