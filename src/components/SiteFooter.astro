---
import { siteConfig } from '../site.config';
import KeystoneBulletIcon from './KeystoneBulletIcon.astro';

const legal = [
	{ href: '/terms/', label: 'Terms' },
	{ href: '/conditions/', label: 'Conditions' },
	{ href: '/cookies/', label: 'Cookies' },
] as const;

const serviceChoices = [
	{ value: 'private-renovations', label: 'Private renovations' },
	{ value: 'landlord-refreshes', label: 'Landlord refreshes' },
	{ value: 'pre-sale', label: 'Pre-sale preparation' },
	{ value: 'general', label: 'General enquiry' },
	{ value: 'other', label: 'Other' },
] as const;

/** Footer “at a glance”, keep in sync with the contact form service dropdown. */
const footerFocusAreas = serviceChoices
	.filter(({ value }) => value !== 'other')
	.map(({ label }) => label);
---

<footer class="site-footer" id="site-footer">
	<div class="site-footer__inner">
		<div class="site-footer__grid">
			<div class="site-footer__intro">
				<a class="site-footer__logo" href="/" aria-label={`${siteConfig.name}, home`}>
					<img
						class="site-footer__logo-img"
						src="/brand/keystone-logo.png"
						alt=""
						width="889"
						height="285"
						decoding="async"
					/>
				</a>
				<p class="site-footer__kicker">The Keystone touch</p>
				<p class="site-footer__body">{siteConfig.tagline}</p>
				<hr class="site-footer__divider" aria-hidden="true" />
				<div class="site-footer__focus">
					<h2 class="site-footer__focus-heading" id="footer-focus-heading">Our focus</h2>
					<ul class="site-footer__focus-grid" aria-labelledby="footer-focus-heading">
						{
							footerFocusAreas.map((label) => (
								<li class="site-footer__focus-chip">
									<span class="site-footer__focus-icon" aria-hidden="true">
										<KeystoneBulletIcon />
									</span>
									<span class="site-footer__focus-text">{label}</span>
								</li>
							))
						}
					</ul>
				</div>
				<div class="site-footer__contact-card" aria-label="Phone and email">
					<div class="site-footer__contact-card-row">
						<span class="site-footer__contact-icon" aria-hidden="true">
							<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
								<path
									d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.86.3 1.7.54 2.5a2 2 0 0 1-.47 2.1L8.09 9.9a16 16 0 0 0 6 6l1.58-1.58a2 2 0 0 1 2.1-.48c.8.24 1.64.42 2.5.54A2 2 0 0 1 22 16.92z"
									stroke="currentColor"
									stroke-width="1.75"
									stroke-linecap="round"
									stroke-linejoin="round"
								/>
							</svg>
						</span>
						<a class="site-footer__contact-phone" href={`tel:${siteConfig.phoneTel}`}>
							{siteConfig.phoneDisplay}
						</a>
					</div>
					<div class="site-footer__contact-card-row">
						<span class="site-footer__contact-icon" aria-hidden="true">
							<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
								<rect
									x="3"
									y="5"
									width="18"
									height="14"
									rx="2"
									stroke="currentColor"
									stroke-width="1.75"
									stroke-linecap="round"
									stroke-linejoin="round"
								/>
								<path
									d="m3 7 7.89 5.26a2 2 0 0 0 2.22 0L21 7"
									stroke="currentColor"
									stroke-width="1.75"
									stroke-linecap="round"
									stroke-linejoin="round"
								/>
							</svg>
						</span>
						<div
							class="site-footer__contact-email-block"
							data-enquiry-email={siteConfig.enquiryEmail}
						>
							<a
								class="site-footer__contact-email-trigger"
								href={`mailto:${siteConfig.enquiryEmail}`}
								aria-label={`Send email to ${siteConfig.enquiryEmail}`}
								title={siteConfig.enquiryEmail}
							>
								Email us
							</a>
							<div class="site-footer__contact-email-popover">
								<p class="site-footer__contact-email-popover-label">Address</p>
								<p class="site-footer__contact-email-address">{siteConfig.enquiryEmail}</p>
								<button
									type="button"
									class="site-footer__contact-email-copy type-button-16-700"
									aria-label={`Copy ${siteConfig.enquiryEmail} to clipboard`}
								>
									Copy
								</button>
							</div>
						</div>
					</div>
				</div>
				<p class="site-footer__badge">Leicestershire &amp; Midlands coverage</p>
			</div>

			<div class="site-footer__form-column">
				<h2 class="site-footer__form-title" id="discuss">Request a consultation</h2>
				<!-- Hook form submit to your API / Resend; field names: name, email, phone, service, message, consent -->
				<form
					class="site-footer__form"
					id="footer-consultation-form"
					method="post"
					action="#"
					aria-labelledby="discuss"
				>
					<div class="site-footer__field">
						<label class="site-footer__label" for="footer-name">
							Name <span class="site-footer__req" aria-hidden="true">*</span>
						</label>
						<input
							class="site-footer__input"
							type="text"
							id="footer-name"
							name="name"
							autocomplete="name"
							placeholder="John Smith"
							required
							aria-required="true"
						/>
					</div>
					<div class="site-footer__field">
						<label class="site-footer__label" for="footer-email">
							Email <span class="site-footer__req" aria-hidden="true">*</span>
						</label>
						<input
							class="site-footer__input"
							type="email"
							id="footer-email"
							name="email"
							autocomplete="email"
							inputmode="email"
							placeholder="your.name@email.com"
							required
							aria-required="true"
						/>
					</div>
					<div class="site-footer__field">
						<label class="site-footer__label" for="footer-phone">Telephone</label>
						<span id="footer-phone-desc" class="visually-hidden">
							United Kingdom country code plus 44 is shown. Enter the rest of your number without a leading zero.
						</span>
						<div class="site-footer__phone-wrap">
							<div class="site-footer__phone-affix" aria-hidden="true">
								<span class="site-footer__phone-flag" title="United Kingdom">🇬🇧</span>
								<span class="site-footer__phone-cc">+44</span>
							</div>
							<input
								class="site-footer__input site-footer__input--phone"
								type="tel"
								id="footer-phone"
								name="phone"
								autocomplete="tel"
								inputmode="tel"
								placeholder="+44 then…"
								aria-describedby="footer-phone-desc"
							/>
						</div>
					</div>
					<div class="site-footer__field">
						<label class="site-footer__label" for="footer-service">Which service are you interested in?</label>
						<select class="site-footer__select" id="footer-service" name="service" required>
							<option value="" disabled selected>Select a service</option>
							{
								serviceChoices.map(({ value, label }) => (
									<option value={value}>{label}</option>
								))
							}
						</select>
					</div>
					<div class="site-footer__field">
						<label class="site-footer__label" for="footer-message">Project details</label>
						<textarea
							class="site-footer__textarea"
							id="footer-message"
							name="message"
							rows="5"
							placeholder="Tell us about your project, timing, and anything we should know upfront."
							required
						/>
					</div>
					<div class="site-footer__field site-footer__field--checkbox">
						<input
							type="checkbox"
							id="footer-consent"
							name="consent"
							value="yes"
							required
							aria-required="true"
						/>
						<label class="site-footer__check-label" for="footer-consent">
							<span class="site-footer__req site-footer__req--inline" aria-hidden="true">*</span>
							I understand Keystone Renovations will use these details to respond to my enquiry only. See our{' '}
							<a href="/terms/">Terms</a> and <a href="/cookies/">Cookies</a> pages for more.
						</label>
					</div>
					<div class="site-footer__actions">
						<button type="submit" class="site-footer__submit type-button-16-700">Request consultation</button>
					</div>
				</form>
			</div>
		</div>
	</div>

	<div class="site-footer__bar">
		<div class="site-footer__bar-inner">
			<nav class="site-footer__legal" aria-label="Legal">
				<ul>
					{
						legal.map(({ href, label }) => (
							<li>
								<a href={href}>{label}</a>
							</li>
						))
					}
				</ul>
			</nav>
			<p class="site-footer__credit">
				<a
					href="https://dotwall.co.uk"
					target="_blank"
					rel="noopener noreferrer"
					class="site-footer__credit-link"
				>
					dotwall
				</a>
			</p>
		</div>
	</div>
</footer>

<script>
	document.getElementById('footer-consultation-form')?.addEventListener('submit', (e) => {
		e.preventDefault();
	});

	(() => {
		const block = document.querySelector('.site-footer__contact-email-block');
		const copyBtn = block?.querySelector('.site-footer__contact-email-copy');
		const email = block?.dataset.enquiryEmail;
		if (!block || !copyBtn || !email) return;

		copyBtn.addEventListener('click', async (e) => {
			e.preventDefault();
			try {
				await navigator.clipboard.writeText(email);
				copyBtn.textContent = 'Copied';
			} catch {
				copyBtn.textContent = 'Copy failed';
			}
		});

		block.addEventListener('pointerleave', () => {
			copyBtn.textContent = 'Copy';
		});
	})();
</script>

<style>
	.site-footer {
		background: var(--color-white);
		color: var(--color-dark-gray);
	}

	.site-footer__inner {
		max-width: var(--layout-max-72);
		margin: 0 auto;
		padding: var(--section-pad-y-footer) var(--section-pad-x);
		border-top: 1px solid color-mix(in srgb, var(--color-dark-gray) 8%, var(--color-white));
	}

	.site-footer__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.25rem;
		align-items: start;
	}

	@media (min-width: 960px) {
		.site-footer__grid {
			grid-template-columns: minmax(0, 1fr) minmax(0, 1.08fr);
			gap: clamp(2rem, 5vw, 3.5rem);
		}
	}

	.site-footer__intro {
		max-width: var(--layout-max-34);
		position: relative;
		z-index: 1;
	}

	.site-footer__logo {
		display: inline-flex;
		margin-bottom: 1.25rem;
		text-decoration: none;
	}

	.site-footer__logo:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 4px;
		border-radius: 2px;
	}

	.site-footer__logo-img {
		display: block;
		height: clamp(3.375rem, 6vw, 4.275rem);
		width: auto;
		max-width: min(72vw, 390px);
		object-fit: contain;
	}

	.site-footer__kicker {
		margin: 0 0 0.35rem;
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(0.9375rem, 0.85rem + 0.35vw, 1.125rem);
		line-height: 1.25;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-dark-gray);
	}

	.site-footer__body {
		margin: 0 0 1.25rem;
		max-width: min(100%, 24.5rem);
		font-family: var(--font-body);
		font-weight: 400;
		font-size: clamp(0.9375rem, 0.9rem + 0.15vw, 1.0625rem);
		line-height: 1.65;
		color: color-mix(in srgb, var(--color-dark-gray) 78%, var(--color-gray));
		text-wrap: pretty;
	}

	.site-footer__divider {
		margin: 0 0 1.25rem;
		max-width: min(100%, 24.5rem);
		border: none;
		border-top: 1px solid color-mix(in srgb, var(--color-dark-gray) 12%, var(--color-white));
	}

	.site-footer__focus {
		margin: 0 0 1.25rem;
	}

	.site-footer__contact-card {
		display: flex;
		flex-direction: column;
		row-gap: 0.875rem;
		width: 100%;
		box-sizing: border-box;
		margin: 0 0 1.35rem;
		padding: clamp(1rem, 2.2vw, 1.2rem) clamp(1.15rem, 3vw, 1.4rem);
		background: color-mix(in srgb, var(--color-white-smoke) 72%, var(--color-white));
		border: 1px solid color-mix(in srgb, var(--color-dark-gray) 12%, var(--color-white));
		border-radius: 8px;
		box-shadow:
			0 1px 2px rgba(26, 27, 27, 0.04),
			0 6px 18px rgba(26, 27, 27, 0.07);
		position: relative;
		z-index: 0;
	}

	.site-footer__contact-card-row {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		min-width: 0;
	}

	.site-footer__contact-icon {
		display: flex;
		flex: 0 0 auto;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 8px;
		color: var(--color-dark-khaki);
		background: color-mix(in srgb, var(--color-white) 55%, var(--color-white-smoke));
		border: 1px solid color-mix(in srgb, var(--color-dark-khaki) 22%, var(--color-white));
	}

	.site-footer__contact-icon svg {
		display: block;
	}

	.site-footer__contact-phone,
	.site-footer__contact-email-trigger {
		flex: 0 1 auto;
		min-width: 0;
		font-family: var(--font-heading);
		font-weight: 700;
		color: var(--color-dark-gray);
		text-decoration: none;
		transition: color var(--motion-duration-200) var(--motion-ease-standard);
		font-size: clamp(1.0625rem, 1rem + 0.25vw, 1.1875rem);
		line-height: 1.28;
		letter-spacing: 0.035em;
	}

	.site-footer__contact-email-block {
		position: relative;
		flex: 1 1 auto;
		min-width: 0;
		display: flex;
		align-items: center;
	}

	/* Keeps hover/focus path continuous from the trigger to the popover */
	.site-footer__contact-email-block::after {
		content: '';
		position: absolute;
		left: 0;
		width: 100%;
		top: 100%;
		height: 0.5rem;
		z-index: 19;
	}

	.site-footer__contact-email-popover {
		position: absolute;
		left: 0;
		top: calc(100% + 0.45rem);
		z-index: 20;
		min-width: min(100%, 18rem);
		max-width: min(calc(100vw - 2rem), 22rem);
		padding: 0.75rem 0.85rem;
		background: var(--color-white);
		border: 1px solid color-mix(in srgb, var(--color-dark-gray) 14%, var(--color-white));
		border-radius: 8px;
		box-shadow:
			0 2px 6px rgba(26, 27, 27, 0.08),
			0 14px 36px rgba(26, 27, 27, 0.14);
		opacity: 0;
		visibility: hidden;
		transform: translateY(-4px);
		pointer-events: none;
		transition:
			opacity var(--motion-duration-200) var(--motion-ease-standard),
			visibility var(--motion-duration-200) var(--motion-ease-standard),
			transform var(--motion-duration-200) var(--motion-ease-standard);
	}

	.site-footer__contact-email-block:hover .site-footer__contact-email-popover,
	.site-footer__contact-email-block:focus-within .site-footer__contact-email-popover {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
		pointer-events: auto;
	}

	.site-footer__contact-email-popover-label {
		margin: 0 0 0.25rem;
		font-family: var(--font-body);
		font-weight: 700;
		font-size: 0.625rem;
		line-height: 1.3;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--color-dark-gray) 55%, var(--color-gray));
	}

	.site-footer__contact-email-address {
		margin: 0 0 0.65rem;
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 0.8125rem;
		line-height: 1.45;
		color: var(--color-dark-gray);
		overflow-wrap: anywhere;
		word-break: break-word;
	}

	.site-footer__contact-email-copy {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		box-sizing: border-box;
		padding: 0.55rem 0.85rem;
		border: none;
		border-radius: 3px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-white);
		background: var(--color-dark-khaki);
		cursor: pointer;
		font-size: 0.75rem;
		transition:
			filter var(--motion-duration-200) var(--motion-ease-standard),
			transform var(--motion-duration-200) var(--motion-ease-standard);
	}

	.site-footer__contact-email-copy:hover {
		filter: brightness(1.06);
	}

	.site-footer__contact-email-copy:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	.site-footer__contact-phone:hover,
	.site-footer__contact-email-trigger:hover {
		color: var(--color-dark-khaki);
	}

	.site-footer__contact-phone:focus-visible,
	.site-footer__contact-email-trigger:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 3px;
		border-radius: 2px;
	}

	@media (prefers-reduced-motion: reduce) {
		.site-footer__contact-email-popover {
			transition: none;
		}
	}

	.site-footer__focus-heading {
		margin: 0 0 0.85rem;
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(0.9375rem, 0.85rem + 0.35vw, 1.0625rem);
		line-height: 1.25;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-dark-gray);
	}

	.site-footer__focus-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.55rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	@media (min-width: 22rem) {
		.site-footer__focus-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	.site-footer__focus-chip {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		margin: 0;
		padding: 0.5rem 0.55rem;
		min-height: 2.75rem;
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 0.8125rem;
		line-height: 1.35;
		letter-spacing: 0.02em;
		color: var(--color-dark-gray);
		background: var(--color-white);
		border: 1px solid color-mix(in srgb, var(--color-dark-gray) 16%, var(--color-white));
		border-radius: 8px;
		box-shadow: none;
		transition:
			box-shadow var(--motion-duration-280) var(--motion-ease-standard),
			transform var(--motion-duration-280) var(--motion-ease-standard),
			border-color var(--motion-duration-200) var(--motion-ease-standard);
	}

	.site-footer__focus-chip:hover {
		transform: translateY(-3px);
		border-color: color-mix(in srgb, var(--color-dark-khaki) 35%, var(--color-dark-gray));
		box-shadow:
			0 2px 6px rgba(26, 27, 27, 0.06),
			0 10px 28px rgba(26, 27, 27, 0.12);
	}

	.site-footer__focus-icon {
		display: flex;
		flex-shrink: 0;
		align-items: center;
		justify-content: center;
	}

	.site-footer__focus-icon :global(svg) {
		display: block;
		width: 1.125rem;
		height: 1.125rem;
	}

	.site-footer__focus-text {
		flex: 1;
		min-width: 0;
	}

	@media (prefers-reduced-motion: reduce) {
		.site-footer__focus-chip {
			transition:
				box-shadow var(--motion-duration-200) var(--motion-ease-standard),
				border-color var(--motion-duration-200) var(--motion-ease-standard);
		}

		.site-footer__focus-chip:hover {
			transform: none;
		}
	}

	.site-footer__badge {
		display: inline-flex;
		align-items: center;
		margin: 0;
		padding: 0.45rem 0.85rem;
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 0.8125rem;
		line-height: 1.35;
		letter-spacing: 0.02em;
		color: color-mix(in srgb, var(--color-dark-gray) 72%, var(--color-gray));
		background: var(--color-white-smoke);
		border: 1px solid color-mix(in srgb, var(--color-dark-gray) 8%, var(--color-white));
		border-radius: 999px;
	}

	.site-footer__form {
		margin: 0;
		padding: clamp(1.35rem, 3.2vw, 2rem);
		background: color-mix(in srgb, var(--color-white-smoke) 55%, var(--color-white));
		border: 1px solid color-mix(in srgb, var(--color-dark-gray) 12%, var(--color-white));
		border-radius: 8px;
		box-shadow:
			0 1px 2px rgba(26, 27, 27, 0.04),
			0 6px 20px rgba(26, 27, 27, 0.07);
	}

	.site-footer__form-column {
		min-width: 0;
	}

	.site-footer__form-title {
		margin: 0 0 0.85rem;
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1rem, 0.92rem + 0.35vw, 1.1875rem);
		line-height: 1.25;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--color-dark-gray);
	}

	.site-footer__field {
		margin-bottom: 1.1rem;
	}

	.site-footer__label {
		display: block;
		margin-bottom: 0.4rem;
