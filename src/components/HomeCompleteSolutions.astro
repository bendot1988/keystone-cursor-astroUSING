---
const intro = 'One standard, whatever the property, brief, or budget.';

const cards = [
	{
		title: 'Dream Home Ideas',
		body: 'Shape your forever-home vision into a clear brief, sensible phases, and workmanship built to live with.',
		imageSrc: '/images/hero-interior.jpg',
		imageAlt: 'Placeholder: dream home renovation',
	},
	{
		title: 'Make Overs',
		body: 'Room-by-room or full-property updates with the right trades, materials, and finish matched to your budget.',
		imageSrc: '/images/services/fixtures-fittings.png',
		imageAlt: 'Placeholder: property make over',
	},
	{
		title: 'DIY Rescues',
		body: 'We assess what is salvageable and put structure, services, and surfaces right, calmly and professionally.',
		imageSrc: '/images/services/structural-design.png',
		imageAlt: 'Placeholder: DIY rescue project',
	},
	{
		title: 'Getting Ready to Sell',
		body: 'Help your property stand out for the right buyers, with over ten years alongside stagers and estate agents across the UK.',
		imageSrc: '/images/services/decor-landscaping.png',
		imageAlt: 'Placeholder: preparing a home to sell',
	},
	{
		title: 'Tenancy Changeovers',
		body: 'Durable landlord revamps on commercial timelines. Cost-conscious work, ready for the next tenant.',
		imageSrc: '/images/services/electrical-plumbing.png',
		imageAlt: 'Placeholder: tenancy changeover revamp',
	},
] as const;
---

<section class="complete-solutions" aria-labelledby="complete-solutions-heading">
	<div class="complete-solutions__inner">
		<header class="complete-solutions__header">
			<h2 id="complete-solutions-heading" class="complete-solutions__title type-h2-48-700 kr-motion-enter-fade-up-sm">
				Complete property solutions
			</h2>
			<p class="complete-solutions__intro type-large-body-18-400 kr-motion-enter-fade-up-sm kr-motion-delay-1">{intro}</p>
		</header>

		<div class="complete-solutions__grid">
			{
				cards.map(({ title, body, imageSrc, imageAlt }, i) => (
					<article
						class:list={[
							'complete-solutions__card',
							'kr-motion-enter-fade-up-sm',
							i % 3 === 1 ? 'kr-motion-delay-1' : undefined,
							i % 3 === 2 ? 'kr-motion-delay-2' : undefined,
						]}
					>
						<div class="complete-solutions__media">
							<img
								class="complete-solutions__image"
								src={imageSrc}
								alt={imageAlt}
								width="640"
								height="400"
								loading="lazy"
								decoding="async"
							/>
						</div>
						<div class="complete-solutions__body">
							<h3 class="complete-solutions__card-title type-h3-20-700">{title}</h3>
							<p class="complete-solutions__card-body type-large-body-18-400">{body}</p>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.complete-solutions {
		background: var(--color-white);
		padding: var(--section-pad-y-complete) var(--section-pad-x);
	}

	.complete-solutions__inner {
		max-width: var(--layout-max-72);
		margin: 0 auto;
		min-width: 0;
	}

	.complete-solutions__header {
		text-align: center;
		max-width: var(--layout-max-48);
		margin: 0 auto 1.75rem;
	}

	.complete-solutions__title {
		margin: 0 0 0.65rem;
		color: var(--color-dark-gray);
	}

	.complete-solutions__intro {
		margin: 0;
		text-align: center;
		color: color-mix(in srgb, var(--color-dark-gray) 78%, var(--color-gray));
	}

	.complete-solutions__grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 1.15rem;
		align-items: stretch;
	}

	@media (min-width: 36rem) {
		.complete-solutions__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	/* 3×2, top row of three, bottom row of two centred */
	@media (min-width: 52rem) {
		.complete-solutions__grid {
			grid-template-columns: repeat(6, minmax(0, 1fr));
			gap: 1.25rem;
		}

		.complete-solutions__card {
			grid-column: span 2;
		}

		.complete-solutions__card:nth-child(4) {
			grid-column: 1 / span 3;
		}

		.complete-solutions__card:nth-child(5) {
			grid-column: 4 / span 3;
		}
	}

	.complete-solutions__card {
		min-width: 0;
		display: flex;
		flex-direction: column;
		background: var(--color-white-smoke);
		text-align: left;
		border-radius: 10px;
		overflow: hidden;
		box-shadow:
			0 1px 2px rgba(26, 27, 27, 0.04),
			0 4px 14px rgba(26, 27, 27, 0.06),
			0 10px 28px rgba(26, 27, 27, 0.07);
		transition:
			box-shadow var(--motion-duration-280) var(--motion-ease-standard),
			transform var(--motion-duration-280) var(--motion-ease-standard);
	}

	.complete-solutions__card:hover {
		box-shadow:
			0 2px 4px rgba(26, 27, 27, 0.06),
			0 8px 22px rgba(26, 27, 27, 0.09),
			0 18px 40px rgba(26, 27, 27, 0.08);
		transform: translateY(-2px);
	}

	@media (prefers-reduced-motion: reduce) {
		.complete-solutions__card {
			transition: none;
		}

		.complete-solutions__card:hover {
			transform: none;
		}
	}

	.complete-solutions__media {
		overflow: hidden;
		line-height: 0;
	}

	.complete-solutions__image {
		display: block;
		width: 100%;
		height: clamp(5rem, 11vw, 7.5rem);
		object-fit: cover;
		object-position: center;
		transition: transform var(--motion-duration-380) var(--motion-ease-out-expo);
	}

	.complete-solutions__card:hover .complete-solutions__image {
		transform: scale(1.03);
	}

	@media (prefers-reduced-motion: reduce) {
		.complete-solutions__image {
			transition: none;
		}

		.complete-solutions__card:hover .complete-solutions__image {
			transform: none;
		}
	}

	.complete-solutions__body {
		display: flex;
		flex-direction: column;
		flex: 1;
		padding: clamp(0.95rem, 2vw, 1.25rem);
	}

	.complete-solutions__card-title {
		margin: 0 0 0.5rem;
		text-align: left;
		text-transform: uppercase;
		color: var(--color-dark-gray);
		overflow-wrap: break-word;
	}

	.complete-solutions__card-body {
		margin: 0;
		text-align: left;
		text-wrap: pretty;
		color: color-mix(in srgb, var(--color-dark-gray) 82%, var(--color-gray));
		font-size: clamp(0.9375rem, 0.9rem + 0.15vw, 1.0625rem);
		line-height: 1.55;
	}
</style>
