---
/** Small keystone + ring mark for list bullets (matches brand keystone motif). */
interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<svg
	class:list={['keystone-bullet-icon', className]}
	viewBox="0 0 32 32"
	width="24"
	height="24"
	aria-hidden="true"
	focusable="false"
>
	<!-- Masonry keystone: wide top, narrow base (matches brand trapezoid, not a pointed wedge). -->
	<path fill="var(--color-card-icon-gold)" d="M2 5h28l-8 22H10L2 5z" />
	<circle cx="16" cy="15.5" r="5.75" fill="none" stroke="var(--color-white)" stroke-width="2.5" />
</svg>
