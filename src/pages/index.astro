---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHero from '../components/HomeHero.astro';
import HomeCompleteSolutions from '../components/HomeCompleteSolutions.astro';
import HomeImageBreak from '../components/HomeImageBreak.astro';
import HomeHowWeHelp from '../components/HomeHowWeHelp.astro';
import HomeTestimonials from '../components/HomeTestimonials.astro';
import { siteConfig } from '../site.config';
---

<BaseLayout
	title={siteConfig.defaultTitle}
	description="Keystone Renovations: home renovations in Leicestershire and beyond. Complete property solutions, proven process, and client-backed delivery."
>
	<main id="main-content">
		<HomeHero />
		<HomeCompleteSolutions />
		<HomeTestimonials />
		<HomeImageBreak />
		<HomeHowWeHelp />
	</main>
</BaseLayout>
