---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import VersionSwitcher from '../components/VersionSwitcher.astro';
import { siteConfig } from '../site.config';

interface Props {
	/** Document `<title>`, keep under ~60 characters for search snippets. */
	title?: string;
	/** Unique meta description for this page. */
	description?: string;
	/** Absolute or site-root path for canonical URL. */
	canonicalPath?: string;
	/** Optional Open Graph / Twitter image (absolute URL preferred). */
	image?: URL | string;
	/** Robots directive, e.g. `noindex, nofollow` for drafts. */
	robots?: string;
}

const {
	title = siteConfig.defaultTitle,
	description = siteConfig.defaultDescription,
	canonicalPath,
	image,
	robots = 'index, follow',
} = Astro.props;

const absoluteSite = Astro.site ?? new URL(Astro.url.origin);
const canonicalURL = new URL(canonicalPath ?? Astro.url.pathname, absoluteSite);
const pageTitle = title === siteConfig.defaultTitle ? title : `${title} | ${siteConfig.name}`;

const ogImage =
	image !== undefined
		? typeof image === 'string'
			? new URL(image, absoluteSite)
			: image
		: undefined;
---

<!doctype html>
<html lang={siteConfig.locale}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
		<link rel="canonical" href={canonicalURL.href} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={siteConfig.name} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:locale" content={siteConfig.locale.replace('-', '_')} />
		{ogImage && <meta property="og:image" content={ogImage.href} />}

		<!-- Twitter -->
		<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		{ogImage && <meta name="twitter:image" content={ogImage.href} />}

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="any" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300&family=Open+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300&display=swap"
			rel="stylesheet"
		/>

		<noscript>
			<style>
				.kr-motion-enter-fade-in,
				.kr-motion-enter-fade-up,
				.kr-motion-enter-fade-up-sm,
				.kr-motion-enter-fade-down-sm {
					opacity: 1 !important;
					transform: none !important;
				}
			</style>
		</noscript>

		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				'@context': 'https://schema.org',
				'@type': 'HomeAndConstructionBusiness',
				name: siteConfig.name,
				description: siteConfig.defaultDescription,
				url: absoluteSite.href,
				telephone: siteConfig.phoneTel,
				areaServed: 'GB',
			})}
		/>
	</head>
	<body class="site-body">
		<a class="skip-link" href="#main-content">Skip to main content</a>
		<SiteHeader pathname={Astro.url.pathname} />
		<slot />
		<SiteFooter />
		<VersionSwitcher />
		<script>
			import { initKrMotionEntrances } from '../scripts/kr-motion-entrances';
			initKrMotionEntrances();
		</script>
	</body>
</html>
